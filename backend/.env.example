APP_ENV=development
APP_NAME=AmazonRecs
PORT=5000
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000
RUN_ML_EVAL_ON_STARTUP=false

# Database backend: postgres or json
DB_BACKEND=postgres

# Hosted Postgres
# If your password contains special characters like @ or :, URL-encode them.
DATABASE_URL=postgresql://postgres:your-password@db.example.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:your-password@db.example.supabase.co:5432/postgres

# Hosted Redis / Valkey
REDIS_URL=redis://localhost:6379/0

# Legacy / optional Mongo configuration
MONGO_URI=
DB_NAME=amazon_recsys

# SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=
